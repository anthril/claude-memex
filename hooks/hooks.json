{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/session-start-context.py", "timeout": 5000 },
          { "type": "command", "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/update-check.py", "timeout": 5000 }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/user-prompt-context.py", "timeout": 5000 }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/path-guard.py", "timeout": 5000 },
          { "type": "command", "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/doc-required.py", "timeout": 5000 },
          { "type": "command", "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/autopilot-write-guard.py", "timeout": 5000 }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          { "type": "command", "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/readme-required.py", "timeout": 5000 },
          { "type": "command", "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ingest-doc-link.py", "timeout": 5000 }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          { "type": "command", "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/frontmatter-precheck.py", "timeout": 5000 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/frontmatter-check.py", "timeout": 5000 },
          { "type": "command", "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/index-update.py", "timeout": 5000 }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/stop-log-append.py", "timeout": 10000 },
          { "type": "command", "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/stop-stale-check.py", "timeout": 10000 },
          { "type": "command", "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/stop-open-questions-check.py", "timeout": 5000 },
          { "type": "command", "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/stop-project-owner-actions-check.py", "timeout": 5000 }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          { "type": "command", "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/autopilot-subagent-stop.py", "timeout": 5000 }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          { "type": "command", "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/autopilot-notify.py", "timeout": 5000 }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          { "type": "command", "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/precompact-snapshot.py", "timeout": 10000 }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          { "type": "command", "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/session-end-log.py", "timeout": 5000 }
        ]
      }
    ]
  }
}
